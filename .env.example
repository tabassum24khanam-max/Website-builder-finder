# =========================================
#  LeadHunter AI — Configuration
# =========================================
#  1. Copy this file → rename to ".env"
#  2. Fill in your keys below
#  3. Run: npm install && npm start
# =========================================

# REQUIRED — Serper.dev key. This is the MAIN key: it powers business discovery
# (Google Maps), plus finding websites, phones, Instagram and LinkedIn.
# Free tier = 2,500 searches. Get one at https://serper.dev
SERPER_API_KEY=

# AI PROVIDER — set ONE of these two. DeepSeek is the cheap option and is
# preferred automatically when its key is set.
#
# Option A (cheapest): DeepSeek — https://platform.deepseek.com → API Keys.
# Uses their latest chat model ("deepseek-chat") for everything.
DEEPSEEK_API_KEY=

# Option B: OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-paste-your-key-here

# Optional: OpenAI model (default: gpt-4o-mini — cheap & fast).
OPENAI_MODEL=gpt-4o-mini

# Optional: model for "AI deep search" mode (default: gpt-4o — a frontier model
# for human-level judgment: deciding which number truly belongs to the business,
# rejecting building switchboards / wrong-region numbers, confirming the right
# Instagram). Falls back to OPENAI_MODEL automatically if the key can't access it.
AI_MODE_MODEL=gpt-4o

# RECOMMENDED: Google Places API key. When set, it becomes the PRIMARY source —
# every business comes back with the exact phone number + website that Google
# Maps shows (Serper cannot return those). This is what makes the phone numbers
# correct. Enable "Places API (New)" in Google Cloud. Free $200/month credit
# covers ~1,000+ searches. Leave blank to run free on Serper only (some phones
# that live only in the Maps panel will then be blank).
GOOGLE_PLACES_API_KEY=

# Optional: Google Maps JavaScript API key. With it, the search-form map gains
# real click-to-drop-pin. Without it, the map still works (keyless Google embed,
# movable, location set by typing). Browser key — create in Google Cloud →
# Credentials, enable "Maps JavaScript API" + "Geocoding API", and restrict by
# HTTP referrer (e.g. *.up.railway.app/*). Free tier: $200/mo credit.
GOOGLE_MAPS_API_KEY=

# Optional: Hunter.io key for extra email finding (free: 25/month).
HUNTER_API_KEY=

# App port (default: 3000).
PORT=3000

# Where to store the SQLite database (Railway: set to /data and mount a Volume).
DATA_DIR=.

# Delay between businesses in ms (gentle pacing; default 300).
SCRAPE_DELAY_MS=300
