# =========================================
#  LeadHunter AI — Configuration
# =========================================
#  1. Copy this file → rename to ".env"
#  2. Fill in your keys below
#  3. Run: npm install && npm start
# =========================================

# REQUIRED — Serper.dev key. This is the MAIN key: it powers business discovery
# (Google Maps), plus finding websites, phones, Instagram and LinkedIn.
# Free tier = 2,500 searches. Get one at https://serper.dev
SERPER_API_KEY=

# REQUIRED — OpenAI key (website classification + lead scoring + outreach text).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-paste-your-key-here

# Optional: OpenAI model (default: gpt-4o-mini — cheap & fast).
OPENAI_MODEL=gpt-4o-mini

# Optional: Google Places API key. A discovery fallback if Serper returns
# nothing. Leave blank to skip it. https://console.cloud.google.com
GOOGLE_PLACES_API_KEY=

# Optional but recommended: Google Maps JavaScript API key — powers the
# interactive map on the search form (real Google Maps with pan/zoom/tap-to-pin).
# Leave blank and the map falls back to OpenStreetMap. This is a BROWSER key:
# create it in Google Cloud → APIs & Services → Credentials, enable
# "Maps JavaScript API" + "Geocoding API", then restrict it by HTTP referrer
# (e.g. *.up.railway.app/*) so it can't be abused. Free tier: $200/mo credit.
GOOGLE_MAPS_API_KEY=

# Optional: Hunter.io key for extra email finding (free: 25/month).
HUNTER_API_KEY=

# App port (default: 3000).
PORT=3000

# Where to store the SQLite database (Railway: set to /data and mount a Volume).
DATA_DIR=.

# Delay between businesses in ms (gentle pacing; default 300).
SCRAPE_DELAY_MS=300
