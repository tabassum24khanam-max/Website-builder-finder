# =========================================
#  LeadHunter AI v2 — Configuration
# =========================================
#  1. Copy this file → rename to ".env"
#  2. Fill in your keys below
#  3. Run: npm install && npm run install-browsers && npm start
# =========================================

# REQUIRED — OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-paste-your-key-here

# Optional: OpenAI model to use (default: gpt-4o-mini — cheap & fast)
# Use gpt-4o for higher quality results (costs ~10x more)
OPENAI_MODEL=gpt-4o-mini

# App port (default: 3000)
PORT=3000

# Set to "true" on Railway or any server without a display
HEADLESS=false

# Where to store the database (Railway: set to /data and mount a Volume)
DATA_DIR=.

# Optional: Hunter.io API key for better email finding (free: 25/month)
# Sign up at https://hunter.io
HUNTER_API_KEY=

# Optional: Delay between actions in ms (higher = less likely to be blocked)
# Default: 1500
SCRAPE_DELAY_MS=1500
