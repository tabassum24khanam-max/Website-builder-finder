# =============================================
#  LEAD GEN DASHBOARD - CONFIGURATION
# =============================================
#  1. Make a copy of this file and rename it to ".env"
#  2. Paste your OpenAI API key below (starts with sk-...)
#  3. Save the file. Done.
# =============================================

OPENAI_API_KEY=sk-paste-your-key-here

# Optional: change the port the dashboard runs on
PORT=3000

# Optional: set to true to hide the Chrome browser window while scraping
# (default false = you can see the scraper working). Useful on a headless server.
HEADLESS=false
